import json
import tempfile
import unittest
from pathlib import Path

from app.plugins import (
    BackendPluginLoader,
    PluginLoadError,
    PluginManifest,
    PluginManifestError,
)


class PluginManifestTests(unittest.TestCase):
    def test_manifest_normalizes_and_deduplicates(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            path = Path(directory) / "plugin.json"
            path.write_text(
                json.dumps(
                    {
                        "id": "Example_Plugin",
                        "name": " Example ",
                        "version": "1.0.0",
                        "capabilities": ["audit", "audit"],
                    }
                ),
                encoding="utf-8",
            )

            manifest = PluginManifest.from_path(path)

            self.assertEqual(manifest.plugin_key, "example_plugin")
            self.assertEqual(manifest.name, "Example")
            self.assertEqual(manifest.capabilities, ("audit",))

    def test_manifest_rejects_invalid_entrypoint(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            path = Path(directory) / "plugin.json"
            path.write_text(
                json.dumps(
                    {
                        "id": "example-plugin",
                        "name": "Example",
                        "version": "1.0.0",
                        "components": {"backend": True},
                        "entrypoints": {
                            "backend": "../escape:Plugin",
                        },
                    }
                ),
                encoding="utf-8",
            )

            manifest = PluginManifest.from_path(path)

            with self.assertRaises(PluginLoadError):
                loader = BackendPluginLoader()
                import asyncio
                asyncio.run(loader.load(Path(directory), manifest))


class PluginLoaderTests(unittest.IsolatedAsyncioTestCase):
    async def test_load_start_health_stop_unload(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            root = Path(directory)
            plugin_root = root / "example-plugin"
            plugin_root.mkdir()

            manifest_path = plugin_root / "plugin.json"
            manifest_path.write_text(
                json.dumps(
                    {
                        "id": "example-plugin",
                        "name": "Example",
                        "version": "1.0.0",
                        "components": {"backend": True},
                        "entrypoints": {
                            "backend": "backend.plugin:Plugin",
                        },
                    }
                ),
                encoding="utf-8",
            )

            backend_dir = plugin_root / "backend"
            backend_dir.mkdir()

            (backend_dir / "__init__.py").write_text("", encoding="utf-8")

            (backend_dir / "plugin.py").write_text(
                "from app.plugins import BackendPlugin\n"
                "\n"
                "class Plugin(BackendPlugin):\n"
                "    async def startup(self):\n"
                "        self.running = True\n"
                "\n"
                "    async def shutdown(self):\n"
                "        self.running = False\n"
                "\n"
                "    async def healthcheck(self):\n"
                "        return {\n"
                "            'status': 'healthy',\n"
                "            'running': getattr(self, 'running', False),\n"
                "        }\n",
                encoding="utf-8",
            )

            manifest = PluginManifest.from_path(manifest_path)
            loader = BackendPluginLoader()

            loaded = await loader.load(plugin_root, manifest)

            self.assertEqual(loaded.manifest.plugin_key, "example-plugin")
            self.assertTrue(loaded.instance.running)

            health = await loaded.instance.healthcheck()

            self.assertEqual(health["status"], "healthy")
            self.assertTrue(health["running"])

            unloaded = await loader.unload("example-plugin")

            self.assertTrue(unloaded)
            self.assertNotIn("example-plugin", loader.loaded)

    async def test_backend_component_requires_entrypoint(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            plugin_root = Path(directory) / "broken-plugin"
            plugin_root.mkdir()

            manifest_path = plugin_root / "plugin.json"
            manifest_path.write_text(
                json.dumps(
                    {
                        "id": "broken-plugin",
                        "name": "Broken",
                        "version": "1.0.0",
                        "components": {"backend": True},
                    }
                ),
                encoding="utf-8",
            )

            with self.assertRaises(PluginManifestError):
                PluginManifest.from_path(manifest_path)


if __name__ == "__main__":
    unittest.main()
