{
  "id": "example-translator",
  "name": "Example Translator Plugin",
  "version": "0.1.0",
  "description": "Reference manifest for the ShieldNet plugin registry.",
  "author": "LRM-IT",
  "min_core": "7.0.0",
  "components": {
    "backend": false,
    "frontend": false,
    "bot": false
  },
  "capabilities": [
    "translation"
  ],
  "permissions": [
    "translator.use",
    "translator.admin"
  ],
  "backend_entrypoint": "backend.plugin:Plugin",
  "sdk_version": "1"
}
